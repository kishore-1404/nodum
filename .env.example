# ╔═══════════════════════════════════════════════════════╗
# ║  Nodum — Environment Configuration                   ║
# ║  Copy this file to .env and fill in your values       ║
# ╚═══════════════════════════════════════════════════════╝

# ── Database ─────────────────────────────────────────────
# PostgreSQL connection string (requires pgvector extension)
NODUM_DATABASE_URL=postgres://nodum:nodum_dev_password@localhost:5432/nodum
DB_PASSWORD=nodum_dev_password

# ── Server ───────────────────────────────────────────────
NODUM_HOST=0.0.0.0
NODUM_PORT=8080

# ── Security ─────────────────────────────────────────────
# CHANGE THIS in production — used for JWT signing
NODUM_JWT_SECRET=change-me-to-a-random-64-char-string

# ── LLM Providers ───────────────────────────────────────
# Set at least one. Users can also configure their own keys
# via the Settings page.

# Anthropic Claude (recommended default)
NODUM_CLAUDE_API_KEY=

# OpenAI (also used for embeddings)
NODUM_OPENAI_API_KEY=

# Google Gemini
NODUM_GEMINI_API_KEY=

# ── Embeddings ───────────────────────────────────────────
# Which provider to use for generating embeddings
# Options: openai, gemini
NODUM_EMBEDDING_PROVIDER=openai

# ── Storage ──────────────────────────────────────────────
NODUM_UPLOAD_DIR=./uploads
NODUM_MAX_FILE_SIZE_MB=50

# ── Logging ──────────────────────────────────────────────
RUST_LOG=nodum=info,tower_http=debug
